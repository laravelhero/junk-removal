---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import Icon from '../../components/Icon.astro';
import { posts, formatDate } from '../../data/posts';

const featured = posts.filter((p) => p.featured);
const rest = posts.filter((p) => !p.featured);
const lead = featured[0] ?? posts[0];
const secondary = featured.slice(1);
---

<Layout
  title="Junk Removal Blog & Resources"
  description="Tips, guides and sustainability stories from ClearOut Junk Removal — estate downsizing, eco-friendly disposal, Madison junk removal pricing and practical cleanout checklists."
  path="/blog"
>
  <PageHero
    eyebrow="The ClearOut Journal"
    title="Practical guides for a clutter-free life."
    subtitle="Downsizing playbooks, transparent pricing breakdowns and the story of where your junk really goes."
    image="https://images.unsplash.com/photo-1532012197267-da84d127e765?auto=format&fit=crop&w=2000&q=80"
    crumbs={[{ label: 'Home', href: '/' }, { label: 'Blog' }]}
  />

  <!-- Featured -->
  <section class="bg-white py-16 sm:py-20">
    <div class="container-edge">
      <div class="grid gap-8 lg:grid-cols-2">
        <!-- Lead story -->
        <a href={`/blog/${lead.slug}`} class="card-lift group flex flex-col overflow-hidden rounded-3xl bg-ink-950 text-white">
          <div class="relative h-64 overflow-hidden sm:h-80">
            <img src={lead.cover} alt={lead.title} class="h-full w-full object-cover opacity-80 transition duration-500 group-hover:scale-105" loading="eager" />
            <div class="absolute inset-0 bg-gradient-to-t from-ink-950 to-transparent"></div>
            <span class="absolute left-5 top-5 rounded-full bg-amber-core px-3 py-1 text-[11px] font-bold uppercase tracking-wider text-ink-950">
              {lead.category}
            </span>
          </div>
          <div class="flex flex-1 flex-col p-7">
            <h2 class="font-display text-2xl font-extrabold leading-tight sm:text-3xl">{lead.title}</h2>
            <p class="mt-3 flex-1 text-white/70">{lead.excerpt}</p>
            <div class="mt-5 flex items-center gap-4 text-sm text-white/50">
              <span>{lead.author}</span><span>·</span>
              <span>{formatDate(lead.date)}</span><span>·</span>
              <span>{lead.readMins} min read</span>
            </div>
          </div>
        </a>

        <!-- Secondary featured -->
        <div class="flex flex-col gap-8">
          {
            secondary.map((p) => (
              <a href={`/blog/${p.slug}`} class="card-lift group flex flex-1 gap-5 overflow-hidden rounded-2xl border border-ink-900/10 bg-bone p-4">
                <div class="relative h-full w-32 shrink-0 overflow-hidden rounded-xl sm:w-44">
                  <img src={p.cover} alt={p.title} class="h-full w-full object-cover transition duration-500 group-hover:scale-105" loading="lazy" />
                </div>
                <div class="flex flex-col py-2 pr-2">
                  <span class="text-[11px] font-bold uppercase tracking-wider text-amber-deep">{p.category}</span>
                  <h3 class="mt-1.5 font-display text-lg font-bold leading-snug text-ink-900">{p.title}</h3>
                  <p class="mt-2 line-clamp-2 flex-1 text-sm text-ink-600">{p.excerpt}</p>
                  <div class="mt-3 text-xs text-ink-500">{formatDate(p.date)} · {p.readMins} min</div>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- All articles -->
  <section class="bg-bone py-16 sm:py-20">
    <div class="container-edge">
      <div class="flex items-end justify-between">
        <div>
          <p class="eyebrow">Latest Articles</p>
          <div class="accent-rule"></div>
          <h2 class="mt-4 font-display text-3xl font-extrabold text-ink-900">From the journal</h2>
        </div>
      </div>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          [...rest, ...secondary].map((p) => (
            <a href={`/blog/${p.slug}`} class="card-lift group flex flex-col overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-ink-900/5">
              <div class="relative h-48 overflow-hidden">
                <img src={p.cover} alt={p.title} class="h-full w-full object-cover transition duration-500 group-hover:scale-105" loading="lazy" />
                <span class="absolute left-4 top-4 rounded-full bg-white/90 px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-ink-900">
                  {p.category}
                </span>
              </div>
              <div class="flex flex-1 flex-col p-6">
                <h3 class="font-display text-lg font-bold leading-snug text-ink-900">{p.title}</h3>
                <p class="mt-2 line-clamp-3 flex-1 text-sm text-ink-600">{p.excerpt}</p>
                <div class="mt-4 flex items-center justify-between border-t border-ink-900/5 pt-4 text-xs text-ink-500">
                  <span>{formatDate(p.date)}</span>
                  <span class="inline-flex items-center gap-1 font-bold uppercase tracking-wide text-amber-deep">
                    Read <Icon name="arrow-right" class="h-3.5 w-3.5" />
                  </span>
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Newsletter / CTA -->
  <section class="bg-ink-950 py-16 texture-grid">
    <div class="container-edge text-center">
      <h2 class="font-display text-3xl font-extrabold text-white sm:text-4xl">Got a pile that needs a plan?</h2>
      <p class="mx-auto mt-3 max-w-xl text-white/60">Skip the reading — get a free, upfront quote and let our crew handle the heavy lifting.</p>
      <button @click="$dispatch('open-booking')" class="btn-amber mt-8">Book Your Free Quote</button>
    </div>
  </section>
</Layout>
