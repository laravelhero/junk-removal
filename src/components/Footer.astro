---
import { business, services } from '../data/site';
import Icon from './Icon.astro';
const year = new Date().getFullYear();
---

<footer class="texture-grid bg-ink-950 text-white/70">
  <!-- CTA strip -->
  <div class="border-b border-white/10">
    <div class="container-edge flex flex-col items-center justify-between gap-6 py-12 text-center md:flex-row md:text-left">
      <div>
        <h2 class="font-display text-3xl font-extrabold text-white sm:text-4xl">
          Ready to reclaim your space?
        </h2>
        <p class="mt-2 text-white/60">Same-day quotes across {business.address.city} & the greater {business.address.regionName} metro.</p>
      </div>
      <div class="flex flex-col gap-3 sm:flex-row">
        <button @click="$dispatch('open-booking')" class="btn-amber">Book Your Free Quote</button>
        <a href={business.phoneHref} class="btn-ghost">
          <Icon name="phone" class="h-4 w-4" /> {business.phone}
        </a>
      </div>
    </div>
  </div>

  <!-- Link columns -->
  <div class="container-edge grid gap-10 py-14 sm:grid-cols-2 lg:grid-cols-4">
    <div>
      <a href="/" class="flex items-center gap-3">
        <span class="flex h-10 w-10 items-center justify-center rounded-md bg-amber-core text-ink-950">
          <Icon name="truck" class="h-6 w-6" stroke={1.8} />
        </span>
        <span class="font-display text-2xl font-extrabold text-white">
          CLEAR<span class="text-amber-core">OUT</span>
        </span>
      </a>
      <p class="mt-4 max-w-xs text-sm leading-relaxed">
        Locally owned, fully insured junk removal & hauling. We donate, recycle and dispose
        responsibly so your unwanted items stay out of the landfill.
      </p>
      <div class="mt-5 flex gap-3">
        <a href={business.social.facebook} aria-label="Facebook" class="flex h-9 w-9 items-center justify-center rounded-md bg-white/5 hover:bg-amber-core hover:text-ink-950">
          <svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4"><path d="M13 22v-8h3l1-4h-4V8c0-1.1.3-2 2-2h2V2.1C18.3 2 17 2 15.5 2 12.6 2 11 3.7 11 7v3H8v4h3v8h2Z"/></svg>
        </a>
        <a href={business.social.instagram} aria-label="Instagram" class="flex h-9 w-9 items-center justify-center rounded-md bg-white/5 hover:bg-amber-core hover:text-ink-950">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
        </a>
        <a href={business.social.google} aria-label="Google reviews" class="flex h-9 w-9 items-center justify-center rounded-md bg-white/5 hover:bg-amber-core hover:text-ink-950">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="h-4 w-4"><path d="M21 12a9 9 0 1 1-3-6.7"/><path d="M21 5v4h-4"/></svg>
        </a>
      </div>
    </div>

    <div>
      <h3 class="font-display text-sm font-bold uppercase tracking-[0.2em] text-white">Services</h3>
      <ul class="mt-4 space-y-2.5 text-sm">
        {services.map((s) => (
          <li>
            <a href={`/services/${s.slug}`} class="transition hover:text-amber-bright">{s.title}</a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="font-display text-sm font-bold uppercase tracking-[0.2em] text-white">Company</h3>
      <ul class="mt-4 space-y-2.5 text-sm">
        <li><a href="/about" class="transition hover:text-amber-bright">About Us</a></li>
        <li><a href="/projects" class="transition hover:text-amber-bright">Projects</a></li>
        <li><a href="/gallery" class="transition hover:text-amber-bright">Gallery</a></li>
        <li><a href="/blog" class="transition hover:text-amber-bright">Blog</a></li>
        <li><a href="/contact" class="transition hover:text-amber-bright">Contact & Booking</a></li>
      </ul>
    </div>

    <div>
      <h3 class="font-display text-sm font-bold uppercase tracking-[0.2em] text-white">Get In Touch</h3>
      <ul class="mt-4 space-y-3 text-sm">
        <li class="flex gap-3">
          <span class="mt-0.5 text-amber-core"><Icon name="pin" class="h-5 w-5" /></span>
          <span>{business.address.street}<br />{business.address.city}, {business.address.region} {business.address.postal}</span>
        </li>
        <li class="flex gap-3">
          <span class="text-amber-core"><Icon name="phone" class="h-5 w-5" /></span>
          <a href={business.phoneHref} class="hover:text-amber-bright">{business.phone}</a>
        </li>
        <li class="flex gap-3">
          <span class="text-amber-core"><Icon name="mail" class="h-5 w-5" /></span>
          <a href={business.emailHref} class="hover:text-amber-bright">{business.email}</a>
        </li>
        <li class="flex gap-3">
          <span class="text-amber-core"><Icon name="clock" class="h-5 w-5" /></span>
          <span>{business.hours}</span>
        </li>
      </ul>
    </div>
  </div>

  <!-- Service area row -->
  <div class="border-t border-white/10">
    <div class="container-edge py-6">
      <p class="text-xs uppercase tracking-wider text-white/40">Proudly serving</p>
      <p class="mt-2 text-sm text-white/60">
        {business.serviceAreas.join(' • ')} & surrounding {business.address.regionName} communities.
      </p>
    </div>
  </div>

  <!-- Legal -->
  <div class="border-t border-white/10">
    <div class="container-edge flex flex-col items-center justify-between gap-3 py-6 text-xs text-white/40 sm:flex-row">
      <p>© {year} {business.legalName}. All rights reserved. Licensed & insured in {business.address.regionName}.</p>
      <div class="flex gap-5">
        <a href="/privacy" class="hover:text-white/70">Privacy</a>
        <a href="/terms" class="hover:text-white/70">Terms</a>
        <a href="/sitemap-index.xml" class="hover:text-white/70">Sitemap</a>
      </div>
    </div>
  </div>
</footer>
